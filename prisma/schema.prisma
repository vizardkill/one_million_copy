generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadSource {
  instagram
  facebook
  landing_page
  referido
  otro
}

model Lead {
  id              String     @id @default(uuid())
  name            String
  email           String     @unique
  phone           String?
  source          LeadSource
  productInterest String?    @map("product_interest")
  budget          Decimal?   @db.Decimal(12, 2)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  @@index([source, createdAt(sort: Desc)], map: "idx_leads_source_created_at")
  @@index([createdAt(sort: Desc)], map: "idx_leads_created_at")
  @@index([deletedAt, createdAt(sort: Desc)], map: "idx_leads_deleted_created_at")
  @@map("leads")
}
